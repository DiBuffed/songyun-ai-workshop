# Songyun AI Workshop - Environment Configuration
# Copy this file to .env and adjust the values for your setup.

# --- Download (0%에서 멈출 때) ---
# HF 미러 (한국/중국 등에서 느릴 때): https://hf-mirror.com
# HF_ENDPOINT=https://hf-mirror.com
# HF 토큰 (다운로드 속도 향상, 선택): https://huggingface.co/settings/tokens
# HF_TOKEN=hf_xxxx

# Base model: Hugging Face ID (auto-downloads) or local path
# runwayml/stable-diffusion-v1-5 = smaller, faster first load
# Lykon/dreamshaper-8 = higher quality, ~4GB download
BASE_MODEL_ID=runwayml/stable-diffusion-v1-5

# Path to the Songyun LoRA file (.safetensors) or directory containing it
# Download from: https://civitai.com/models/968377/chinese-painting-in-the-song-dynasty-lora
# Example: C:/models/songyun.safetensors
LORA_PATH=

# Device: cuda (GPU) or cpu
# Leave empty to auto-detect (uses CUDA if available)
DEVICE=

# Default negative prompt (what the model should avoid generating)
DEFAULT_NEGATIVE_PROMPT=ugly, blurry, low quality, distorted, deformed, watermark, text

# Maximum allowed width/height in pixels (to prevent OOM on smaller GPUs)
MAX_IMAGE_SIZE=768

# --- Server / URL (for workshop sharing) ---
# Port (default 8080 - common for web apps)
SERVER_PORT=8080

# URL path. Leave empty for gradio.live (simplest: https://xxx.gradio.live/)
# Or set /songyun-ai-workshop for http://yourserver:8080/songyun-ai-workshop
ROOT_PATH=

# Browser tab title
APP_TITLE=Songyun AI Workshop / 宋韵
